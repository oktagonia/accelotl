module serializer
  #(parameter N = 2,
    parameter WIDTH = 8)
   (input logic                        clk, reset,
    input logic [$clog2(N) - 1:0]      rate, buffer,
    input logic signed [N*WIDTH - 1:0] S,
    output logic signed [WIDTH - 1:0]  z);
   
   logic [$clog2(N)-1:0] state, index, buf_cnt;

   always_ff @(posedge clk, posedge reset)
     if (reset)
       begin
          state <= rate - 1;
          index <= 0;
          buf_cnt <= buffer;
       end
     else if (state == 0)
       begin
          state <= rate - 1;
          index <= 0;
          buf_cnt <= buffer;
       end
     else if (state > 0)
       begin
          state <= state - (buf_cnt == 0 ? 1 : 0);
          index <= index + (buf_cnt == 0 ? 1 : 0);
          buf_cnt <= buf_cnt == 0 ? buf_cnt : buf_cnt - 1;
       end
     else
       begin
          state <= state;
          index <= index;
       end

   assign z = buf_cnt == 0 ? S[index * WIDTH+:WIDTH] : 0;
   
endmodule
